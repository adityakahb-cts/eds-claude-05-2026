#!/bin/sh
# Enforce Conventional Commits format: type(scope): subject
commit_regex='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,100}'
if ! grep -qE "$commit_regex" "$1"; then
  echo ""
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo "Expected:  type(scope): subject"
  echo "Examples:  feat(cards): add hover animation"
  echo "           fix(hero): correct aspect ratio on mobile"
  echo "           chore: update dependencies"
  echo ""
  exit 1
fi

{
  "extends": ["airbnb-base", "prettier"],
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "import/extensions": ["error", { "js": "always" }],
    "linebreak-style": ["error", "unix"],
    "no-param-reassign": [2, { "props": false }]
  },
  "ignorePatterns": ["helix-importer-ui/**", "**/*.min.js"]
}
